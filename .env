# Image version tag
VERSION=2.0.0
# Image name and container hostname
CONTAINER_NAME=autostream
# RTSP listener port
MEDIAMTX_RTSP_PORT=8554
# RTP UDP port
MEDIAMTX_RTP_PORT=8000
# RTCP UDP port
MEDIAMTX_RTCP_PORT=8001
# HLS HTTP port
MEDIAMTX_HLS_PORT=8888
# Stream supervisor UI/API port
STREAM_API_PORT=8080
# Max video bitrate for transcoding (e.g., 3M, 5M, 10M)
# Videos above this bitrate will be transcoded down; leave empty to disable
MAX_VIDEO_BITRATE=2M
# Where the KLV MPEG-TS/UDP feeds are pushed. For the octo-cx stack this is the
# cx-search "video-streaming" service on octo-cx-network, which listens on
# udp://0.0.0.0:<port> and decodes KLV (KlvSink -> AMQP stream.klv -> cx-edge).
# For standalone use, set this to a reachable consumer or a multicast group.
OUTPUT_HOST=video-streaming
# Base UDP port; each stream gets the next port (base, base+1, ...). Kept within
# video-streaming's UDP_START_PORT..UDP_END_PORT range (40000-40100).
UDP_BASE_PORT=40000
